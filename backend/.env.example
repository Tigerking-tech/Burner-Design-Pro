# Security Configuration - Burner Design Pro
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security Settings
RATE_LIMIT=100
RATE_WINDOW=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Environment (development or production)
ENVIRONMENT=development
DEBUG=false

# Application URL (for payment redirects)
# Example: https://your-domain.com  (no trailing slash)
APP_URL=http://localhost:3000

# ============================================================
# LEMON SQUEEZY PAYMENT CONFIGURATION
# ============================================================
# Get your API key here: https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=

# Your Lemon Squeezy store ID (numeric id, visible in store URL)
# Example: https://app.lemonsqueezy.com/stores/<STORE_ID>/...
LEMON_SQUEEZY_STORE_ID=

# The VARIANT ID for your Pro plan (NOT the product id)
# Create a product + variant in your LS store dashboard, copy the variant id.
LEMON_SQUEEZY_PRO_VARIANT_ID=

# Signing secret for the webhook endpoint (generated when you create the webhook)
# Dashboard: Settings → Webhooks → Create new webhook → Signing secret
# Webhook endpoint to register in LS:
#   https://<your-domain>/api/webhooks/lemon-squeezy
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ============================================================
# ADMIN CONFIGURATION
# ============================================================

# Admin user credentials (change these in production!)
ADMIN_EMAIL=admin@burnerpro.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin
