# Security Configuration - Burner Design Pro
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security Settings
RATE_LIMIT=100
RATE_WINDOW=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Environment (development or production)
ENVIRONMENT=development
DEBUG=false

# Application URL (for payment redirects)
APP_URL=http://localhost:3000

# ==========================================
# CREEM PAYMENT CONFIGURATION
# ==========================================

# Creem API Key (get from https://creem.io/dashboard/developers)
CREEM_API_KEY=creem_test_xxxxxxxxxxxxx

# Test Mode (set to "false" for production)
CREEM_TEST_MODE=true

# Creem Webhook Secret (for verifying webhook authenticity)
CREEM_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Product IDs from Creem Dashboard
# Create products in Creem dashboard first, then add their IDs here
CREEM_PRO_PRODUCT_ID=prod_xxxxxxxxxxxxx
CREEM_TEAM_PRODUCT_ID=prod_xxxxxxxxxxxxx
CREEM_PRO_PLUS_PRODUCT_ID=prod_xxxxxxxxxxxxx

# ==========================================
# ADMIN CONFIGURATION
# ==========================================

# Admin user credentials (change these in production!)
ADMIN_EMAIL=admin@burnerpro.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin
