# Security Configuration - Burner Design Pro
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security Settings
RATE_LIMIT=100
RATE_WINDOW=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Environment (development or production)
ENVIRONMENT=development
DEBUG=false

# Application URL (for payment redirects)
# Example: https://your-domain.com  (no trailing slash)
APP_URL=http://localhost:3000

# ============================================================
# PADDLE PAYMENT CONFIGURATION
# ============================================================
# Paddle Vendor Dashboard: https://vendors.paddle.com/
#
# 1) PADDLE_API_KEY
#    Vendor Dashboard → Authentication → API Keys → Generate API key
#
# 2) PADDLE_ENV
#    "sandbox"    — use https://sandbox-api.paddle.com  (test mode)
#    "production" — use https://api.paddle.com         (real payments)
#
# 3) PADDLE_PRO_PRICE_ID
#    The Price ID (pri_xxx) for your Pro plan.
#    Vendor Dashboard → Catalog → Products → (select your product) → Prices →
#    copy the "Price ID" (pri_xxx) for the recurring price.
#
# 4) PADDLE_WEBHOOK_SECRET
#    Vendor Dashboard → Developer Tools → Notifications → New destination
#    → set the URL to https://<your-domain>/api/webhooks/paddle
#    → subscribe to events:
#        • transaction.completed
#        • transaction.refunded
#        • subscription.activated
#        • subscription.updated
#        • subscription.canceled
#        • subscription.past_due
#        • subscription.paused
#        • subscription.expired
#    → copy the generated "Secret key" and paste it here.

PADDLE_API_KEY=
PADDLE_ENV=sandbox
PADDLE_PRO_PRICE_ID=
PADDLE_WEBHOOK_SECRET=

# ============================================================
# ADMIN CONFIGURATION
# ============================================================

# Admin user credentials (change these in production!)
ADMIN_EMAIL=admin@burnerpro.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin
