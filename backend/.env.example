# Security Configuration - Burner Design Pro
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Security Settings
RATE_LIMIT=100
RATE_WINDOW=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Environment (development or production)
ENVIRONMENT=development
DEBUG=false

# Application URL (for payment redirects)
# Example: https://your-domain.com  (no trailing slash)
APP_URL=http://localhost:3000

# ============================================================
# CREEM PAYMENT CONFIGURATION
# ============================================================
# Creem Dashboard: https://creem.io/dashboard
#
# 1. CREEM_API_KEY
#    Dashboard → Developers → API Keys → Generate key
#
# 2. CREEM_TEST_MODE
#    true  = use https://test-api.creem.io (sandbox / testing)
#    false = use https://api.creem.io (production / real payments)
#
# 3. CREEM_PRO_PRODUCT_ID
#    The Product ID (prod_xxx) for your Pro subscription plan.
#    Dashboard → Products → (select product) → copy Product ID
#
# 4. CREEM_WEBHOOK_SECRET
#    Dashboard → Developers → Webhooks → Create new webhook
#    → URL: https://<your-domain>/api/webhooks/creem
#    → Subscribe to events: subscription.created, subscription.activated,
#      subscription.cancelled, subscription.expired, payment.completed,
#      payment.refunded
#    → Copy the signing secret here

CREEM_API_KEY=
CREEM_TEST_MODE=true
CREEM_PRO_PRODUCT_ID=
CREEM_WEBHOOK_SECRET=

# ============================================================
# ADMIN CONFIGURATION
# ============================================================

# Admin user credentials (change these in production!)
ADMIN_EMAIL=admin@burnerpro.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin
